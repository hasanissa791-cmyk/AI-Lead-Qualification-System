    },
    {
      "parameters": {
        "jsCode": "// هذه بيانات وهمية لتشغيل الـ Workflow تلقائياً\nreturn [{\n  json: {\n    full_name: \"عميل تلقائي صباحي\",\n    email: \"example@example.com\",\n    company: \"شركة الصباح\",\n    website: \"https://auto.com\",\n    service: \"استشارات آلية\",\n    budget: 6000,   \n    challenge: \"تحدي تلقائي من الجدولة\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-640, -272],
      "id": "65f4ad6a-8800-4dfd-93b9-b461220de575",
      "name": "Generate Dummy Data"
    },
    {
      "parameters": {
        "jsCode": "// 1. خذ البيانات الأصلية من المدخلات الحالية ($json) وليس من عقدة خارجية\nconst originalData = $json;\n\n// 2. استخرج بيانات الذكاء الاصطناعي من النص\nconst replyText = originalData.output || '';\n\nfunction extractNumber(text) {\n  const match = text.match(/\\d+/);\n  return match ? Number(match[0]) : 0;\n}\n\nfunction extractTextAfter(text, keyword) {\n  const lines = text.split('\\n');\n  for (let line of lines) {\n    if (line.toLowerCase().includes(keyword.toLowerCase())) {\n      return line.replace(/^[^:]*:\\s*/, '').trim();\n    }\n  }\n  const regex = new RegExp(`${keyword}[\\\\s:]+([^\\\\n,.]+)`, 'i');\n  const match = text.match(regex);\n  return match ? match[1].trim() : \"غير متوفر\";\n}\n\nconst extractedData = {\n  lead_score: extractNumber(replyText),\n  summary: extractTextAfter(replyText, 'summary') || extractTextAfter(replyText, 'ملخص'),\n  recommendation: extractTextAfter(replyText, 'recommendation') || extractTextAfter(replyText, 'توصية')\n};\n\n// 3. دمج البيانات الأصلية (من $json) مع البيانات المستخرجة (من AI)\nreturn [{\n  json: {\n    full_name: originalData.full_name || originalData.name || \"غير معروف\",\n    email: originalData.email || \"\",\n    company: originalData.company || \"\",\n    website: originalData.website || \"\",\n    service: originalData.service || \"\",\n    budget: originalData.budget || 0,\n    challenge: originalData.challenge || \"\",\n    ...extractedData\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [160, -272],
      "id": "755e1aeb-c898-46c0-889d-8641d36ba0ca",
      "name": "Extract AI & Merge"
    },
    {
      "parameters": {
        "jsCode": "// استقبل جميع العناصر القادمة (من Aggregate)\nconst items = $input.all();\n\n// ابحث عن العنصر الأول الذي يحتوي على lead_score حقيقي (أكبر من 0)\nlet validItem = items.find(item => Number(item.json.lead_score) > 0);\n\n// إذا لم نجده، حاول العثور على عنصر يحتوي على اسم حقيقي (كحل احتياطي)\nif (!validItem) {\n  validItem = items.find(item => item.json.full_name && item.json.full_name.trim() !== '');\n}\n\n// إذا لم نجد أي شيء، أخرج بيانات افتراضية\nif (!validItem) {\n  return [{\n    json: {\n      full_name: \"لا توجد بيانات\",\n      lead_score: 0,\n      classification: \"Low\"\n    }\n  }];\n}\n\n// استخرج الرقم وتأكد من أنه رقم\nlet score = Number(validItem.json.lead_score) || 0;\n\n// أضف التصنيف إلى العنصر نفسه\nvalidItem.json.classification = score > 70 ? 'High' : 'Low';\nvalidItem.json.lead_score = score;\n\n// أخرج العنصر الصحيح (عنصر واحد فقط)\nreturn [validItem];"
      },
