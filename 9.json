    {
      "parameters": {
        "jsCode": "// 1. استقبل البيانات الخام كما هي من Webhook\nconst rawData = $json;\n\n// 2. دالة ذكية للبحث عن قيمة في أي مكان (الجذر أو الكائنات الفرعية)\nfunction deepFind(obj, keys) {\n  // أولاً: ابحث في الجذر مباشرة\n  for (let key of keys) {\n    if (obj[key] !== undefined && obj[key] !== null && obj[key] !== '') {\n      return obj[key];\n    }\n  }\n  \n  // ثانياً: ابحث داخل أي كائن فرعي (مثل data, body, json, payload)\n  for (let mainKey in obj) {\n    if (typeof obj[mainKey] === 'object' && obj[mainKey] !== null) {\n      const nested = obj[mainKey];\n      for (let key of keys) {\n        if (nested[key] !== undefined && nested[key] !== null && nested[key] !== '') {\n          return nested[key];\n        }\n      }\n    }\n  }\n  \n  // إذا لم يجد شيئاً، يرجع null (وليس قيمة افتراضية)\n  return null;\n}\n\n// 3. تنظيم البيانات (Mapping) باستخدام الدالة أعلاه\nconst organizedData = {\n  full_name: deepFind(rawData, ['full_name', 'name', 'fullName', 'user_name', 'userName']),\n  email: deepFind(rawData, ['email', 'Email', 'mail', 'user_email', 'userEmail']),\n  company: deepFind(rawData, ['company', 'Company', 'organization', 'org']),\n  website: deepFind(rawData, ['website', 'Website', 'web', 'url', 'site']),\n  service: deepFind(rawData, ['service', 'Service', 'product', 'interest']),\n  budget: deepFind(rawData, ['budget', 'Budget', 'price', 'amount', 'value']),\n  challenge: deepFind(rawData, ['challenge', 'Challenge', 'problem', 'need', 'pain_point', 'description'])\n};\n\n// 4. إخراج البيانات المنظمة كما هي (بدون أي تعديل أو فرض)\nreturn [{\n  json: organizedData\n}];"
      },
      "type": "n8n-nodes-base.code",
